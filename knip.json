{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignore": ["drizzle.config.ts", "pw-auth.mjs", "e2e/**"],
  "ignoreBinaries": ["drizzle-kit", "wrangler", "semgrep", "gitleaks"],
  "ignoreExportsUsedInFile": true,
  "workspaces": {
