{
  "name": "legalcode-api",
  "main": "packages/api/src/index.ts",
  "compatibility_date": "2024-12-18",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "legalcode-db",
      "database_id": "placeholder-id"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "AUTH_KV",
      "id": "placeholder-id"
    }
  ],
  "vars": {
    "JWT_SECRET": "",
    "GOOGLE_CLIENT_ID": "",
    "GOOGLE_CLIENT_SECRET": ""
  }
}
