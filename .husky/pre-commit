if ! command -v gitleaks > /dev/null 2>&1; then
  echo "ERROR: gitleaks not installed. Run: brew install gitleaks"
  exit 1
fi
gitleaks protect --staged --verbose

pnpm audit:security --audit-level critical

if ! command -v semgrep > /dev/null 2>&1; then
  echo "ERROR: semgrep not installed. Run: brew install semgrep"
  exit 1
fi
pnpm security:scan --quiet

# TDD enforcement: block commits with implementation files that have no test file
bash scripts/tdd-precommit-check.sh

pnpm lint-staged
pnpm typecheck
pnpm test
